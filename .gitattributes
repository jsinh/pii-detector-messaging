# Normalise line endings across OSes. Without this, a Windows checkout can
# rewrite files with CRLF, which breaks the Makefile, shell scripts, and the
# Docker build (the Linux image expects LF).
* text=auto eol=lf

# Force LF for files that must stay LF even on Windows.
*.py    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.jsonl text eol=lf
*.sh    text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Treat these as binary (never touch line endings).
*.png binary
*.jpg binary
*.ico binary
