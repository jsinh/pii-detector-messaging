# Keep the build context (and image) small and the build cache stable.
.git
.gitignore
.gitattributes
.venv
venv
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local secrets / env — never bake these into an image.
.env
.env.*
!.env.example

# Not needed at runtime.
tests/
data/
scripts/
Dockerfile
.dockerignore
.github/
*.egg-info/
build/
dist/
